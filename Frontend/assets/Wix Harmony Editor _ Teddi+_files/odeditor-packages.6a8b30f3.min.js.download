  .iframe-placeholder {
    background: linear-gradient(135deg, #D4E5F2 0%, #EEE8E5 100%), #F5F7FF;
    padding: 6px;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
  }

  .iframe-placeholder-inner {
    width: 100%;
    height: 100%;
    border: 1px dashed #868AA5;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12px;
    box-sizing: border-box;
    gap: 4px;
  }

  .iframe-placeholder-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 11px;
    height: 11px;
  }
